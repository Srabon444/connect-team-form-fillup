{
  "manifest_version": 3,
  "name": "Daily Timesheet Auto-Filler",
  "version": "1.0.0",
  "description": "Track per-project time with timers, then auto-fill the Techzu Fillout daily timesheet form.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "alarms",
    "notifications",
    "identity"
  ],
  "host_permissions": [
    "https://techzu.fillout.com/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Daily Timesheet",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "789173524951-io688vg8m1geo34nqipg9u19jl1rcb5i.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.file"]
  },
  "key": ""
}
